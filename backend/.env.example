# Sentinel-AI — Environment Variables Template
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Application ──────────────────────────────
APP_NAME=Sentinel-AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── Server ───────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# ── API ──────────────────────────────────────
API_V1_PREFIX=/api/v1
DOCS_URL=/docs
REDOC_URL=/redoc

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Security ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-256-bit-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── Elasticsearch ─────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_VERIFY_CERTS=false

# ── Ollama ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=2048
OLLAMA_TIMEOUT=120

# ── Vector Store ─────────────────────────────
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=./data/vectorstore
EMBEDDING_MODEL=nomic-embed-text

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MITRE ATT&CK ─────────────────────────────
MITRE_LOCAL_CACHE_PATH=./data/mitre-attack.json
MITRE_AUTO_UPDATE=true

# ── Threat Intelligence (optional) ───────────
# MISP_URL=http://misp.internal
# MISP_API_KEY=
# OTX_API_KEY=
# VIRUSTOTAL_API_KEY=
